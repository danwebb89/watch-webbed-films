}

cmd_upload() {
  local file="${1:?Usage: wf upload <video-file>}"
  [[ -f "$file" ]] || die "File not found: $file"
  ensure_auth

  local filesize
  filesize=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null)
  local filename
  filename=$(basename "$file")

  if [[ "$filesize" -lt "$CHUNK_SIZE" ]]; then
    info "Uploading ${filename} ($(( filesize / 1024 / 1024 ))MB)..."
    api POST /api/upload/video -F "video=@${file}" | python3 -m json.tool
  else
    local total_chunks=$(( (filesize + CHUNK_SIZE - 1) / CHUNK_SIZE ))
    local upload_id
    upload_id=$(python3 -c "import uuid; print(uuid.uuid4().hex[:16])")

    info "Chunked upload: ${filename} ($(( filesize / 1024 / 1024 ))MB, ${total_chunks} chunks)"

    local chunk_index=0
    local offset=0
    local tmp_chunk
    tmp_chunk=$(mktemp)
    trap "rm -f '$tmp_chunk'" EXIT

    while [[ $offset -lt $filesize ]]; do
      dd if="$file" bs="$CHUNK_SIZE" skip="$chunk_index" count=1 2>/dev/null > "$tmp_chunk"
      info "  Chunk $((chunk_index + 1))/${total_chunks}..."
      api POST /api/upload/video-chunk \
        -F "uploadId=${upload_id}" \
        -F "chunkIndex=${chunk_index}" \
        -F "totalChunks=${total_chunks}" \
        -F "chunk=@${tmp_chunk}" > /dev/null
      chunk_index=$((chunk_index + 1))
      offset=$((offset + CHUNK_SIZE))
    done

    info "Assembling chunks..."
    ensure_auth
    api POST /api/upload/video-assemble \
      -H "Content-Type: application/json" \
      -d "{\"uploadId\":\"${upload_id}\",\"filename\":\"${filename}\"}" | python3 -m json.tool
  fi
}

cmd_transcode() {
  local id="${1:?Usage: wf transcode <id>}"
  ensure_auth
  api GET "/api/transcode/${id}" | python3 -m json.tool
}

cmd_transcode_wait() {
  local id="${1:?Usage: wf transcode-wait <id>}"
  ensure_auth
  info "Waiting for transcode ${id}..."
  while true; do
    local result
    result=$(api GET "/api/transcode/${id}")
    local status
    status=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('status','unknown'))")
    local progress
    progress=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('progress',0))")

    case "$status" in
      done)
        info "Transcode complete."
        echo "$result" | python3 -m json.tool
        return 0
        ;;
      error)
        info "Transcode failed."
        echo "$result" | python3 -m json.tool
        return 1
        ;;
      *)
        info "  ${status}: ${progress}%"
        sleep 3
        ;;
    esac
  done
}

# Upload + transcode + create film in one command
cmd_add() {
  local file="" title="" slug="" category="" year="" description="" password=""
  local public="true" featured="false" visibility="public"
  local synopsis="" credits="" role_description=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --title)       title="$2"; shift 2 ;;
      --slug)        slug="$2"; shift 2 ;;
      --category)    category="$2"; shift 2 ;;
      --year)        year="$2"; shift 2 ;;
      --description) description="$2"; shift 2 ;;
      --synopsis)    synopsis="$2"; shift 2 ;;
      --credits)     credits="$2"; shift 2 ;;
      --role)        role_description="$2"; shift 2 ;;
      --public)      public="$2"; shift 2 ;;
      --visibility)  visibility="$2"; shift 2 ;;
      --featured)    featured="$2"; shift 2 ;;
      --password)    password="$2"; shift 2 ;;
      -*)            die "Unknown flag: $1" ;;
      *)
        if [[ -z "$file" ]]; then
          file="$1"; shift
        else
          die "Unexpected argument: $1"
        fi
        ;;
    esac
  done
  [[ -n "$file" ]] || die "Usage: wf add <video-file> --title 'Title' [options]"
  [[ -f "$file" ]] || die "File not found: $file"
  [[ -n "$title" ]] || die "--title is required"
  [[ -z "$slug" ]] && slug=$(slugify "$title")

  # Map --public flag to visibility if visibility not explicitly set
  if [[ "$visibility" == "public" && "$public" == "false" ]]; then
    visibility="client"
  fi

  info "==> Uploading $(basename "$file")..."
  local upload_result
  upload_result=$(cmd_upload_raw "$file")
  local transcode_id
  transcode_id=$(echo "$upload_result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('transcodeId',''))")

  if [[ -z "$transcode_id" ]]; then
    die "Upload failed — no transcodeId returned. Response: $upload_result"
  fi

  info "==> Transcoding (id: ${transcode_id})..."
  local transcode_result
  transcode_result=$(cmd_transcode_wait_raw "$transcode_id")
  local video_path thumbnail_path
  video_path=$(echo "$transcode_result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('videoPath', '/assets/videos/' + d.get('output','')))")
  thumbnail_path=$(echo "$transcode_result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('thumbnail',''))")

  info "==> Creating film: ${title}..."
  local create_args=(--title "$title" --slug "$slug" --video "$video_path" --thumbnail "$thumbnail_path")
  [[ -n "$category" ]] && create_args+=(--category "$category")
  [[ -n "$year" ]] && create_args+=(--year "$year")
  [[ -n "$description" ]] && create_args+=(--description "$description")
  [[ -n "$synopsis" ]] && create_args+=(--synopsis "$synopsis")
  [[ -n "$credits" ]] && create_args+=(--credits "$credits")
  [[ -n "$role_description" ]] && create_args+=(--role "$role_description")
  create_args+=(--visibility "$visibility" --featured "$featured")
  [[ -n "$password" ]] && create_args+=(--password "$password")

  cmd_films create "${create_args[@]}"
  info "==> Done! Film '${title}' is live."
}

# Raw upload — returns JSON without pretty-printing (for piping)
cmd_upload_raw() {
  local file="$1"
  ensure_auth

  local filesize
  filesize=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null)
  local filename
  filename=$(basename "$file")

  if [[ "$filesize" -lt "$CHUNK_SIZE" ]]; then
    info "Uploading ${filename} ($(( filesize / 1024 / 1024 ))MB)..."
    api POST /api/upload/video -F "video=@${file}"
  else
    local total_chunks=$(( (filesize + CHUNK_SIZE - 1) / CHUNK_SIZE ))
    local upload_id
    upload_id=$(python3 -c "import uuid; print(uuid.uuid4().hex[:16])")

    info "Chunked upload: ${filename} ($(( filesize / 1024 / 1024 ))MB, ${total_chunks} chunks)"

    local chunk_index=0
    local offset=0
    local tmp_chunk
    tmp_chunk=$(mktemp)
    trap "rm -f '$tmp_chunk'" EXIT

    while [[ $offset -lt $filesize ]]; do
      dd if="$file" bs="$CHUNK_SIZE" skip="$chunk_index" count=1 2>/dev/null > "$tmp_chunk"
      info "  Chunk $((chunk_index + 1))/${total_chunks}..."
      api POST /api/upload/video-chunk \
        -F "uploadId=${upload_id}" \
        -F "chunkIndex=${chunk_index}" \
        -F "totalChunks=${total_chunks}" \
        -F "chunk=@${tmp_chunk}" > /dev/null
      chunk_index=$((chunk_index + 1))
      offset=$((offset + CHUNK_SIZE))
    done

    info "Assembling chunks..."
    ensure_auth
    api POST /api/upload/video-assemble \
      -H "Content-Type: application/json" \
      -d "{\"uploadId\":\"${upload_id}\",\"filename\":\"${filename}\"}"
  fi
}

# Raw transcode wait — returns JSON without pretty-printing
cmd_transcode_wait_raw() {
  local id="$1"
  ensure_auth
  info "Waiting for transcode ${id}..."
  local poll_count=0
  while true; do
    # Re-auth every 20 polls (~60s) to prevent session expiry
    poll_count=$((poll_count + 1))
    if (( poll_count % 20 == 0 )); then
      ensure_auth
    fi
    local result
    result=$(api GET "/api/transcode/${id}")
    local status
    status=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('status','unknown'))" 2>/dev/null || echo "unknown")
    local progress
    progress=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('progress',0))" 2>/dev/null || echo "0")

    case "$status" in
      done)
        info "Transcode complete."
        echo "$result"
        return 0
        ;;
      error)
        info "Transcode failed."
        echo "$result"
        return 1
        ;;
      unknown)
        # Likely auth expired, re-auth and retry
        ensure_auth
        sleep 3
        ;;
      *)
        info "  ${status}: ${progress}%"
        sleep 3
        ;;
    esac
  done
}

cmd_regen_thumbs() {
  local slug="${1:?Usage: wf regen-thumbs <slug>}"
  ensure_auth
  info "Regenerating thumbnails for ${slug}..."
  api POST "/api/films/${slug}/regenerate-thumbs" | python3 -m json.tool
}

cmd_files() {
  local type="${1:-videos}"
  ensure_auth
  case "$type" in
    videos) api GET /api/files/videos | python3 -m json.tool ;;
    thumbs) api GET /api/files/thumbs | python3 -m json.tool ;;
    *) die "Unknown file type: $type (videos|thumbs)" ;;
  esac
}

