# ── Portal Commands ─────────────────────────────────────

cmd_portal() {
  local subcmd="${1:-help}"; shift || true
  case "$subcmd" in
    clients)     cmd_portal_clients "$@" ;;
    projects)    cmd_portal_projects "$@" ;;
    add-version) cmd_portal_add_version "$@" ;;
    upload-resource) cmd_portal_upload_resource "$@" ;;
    migrate-project) cmd_portal_migrate "$@" ;;
    help|--help) cmd_portal_help ;;
    *) die "Unknown portal command: $subcmd (try: wf portal help)" ;;
  esac
}

cmd_portal_clients() {
  local action="${1:-list}"; shift || true
  ensure_auth
  case "$action" in
    list)
      api GET /api/clients | python3 -m json.tool
      ;;
    create)
      local name="" slug="" password="" notes=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --name)     name="$2"; shift 2 ;;
          --slug)     slug="$2"; shift 2 ;;
          --password) password="$2"; shift 2 ;;
          --notes)    notes="$2"; shift 2 ;;
          *) die "Unknown flag: $1" ;;
        esac
      done
      [[ -n "$name" ]] || die "Usage: wf portal clients create --name 'Client Name' [--password pw]"

      local body
      body=$(python3 -c "
import json, sys
d = {'name': sys.argv[1]}
if sys.argv[2]: d['slug'] = sys.argv[2]
if sys.argv[3]: d['password'] = sys.argv[3]
if sys.argv[4]: d['notes'] = sys.argv[4]
print(json.dumps(d))
" "$name" "$slug" "$password" "$notes")

      local result
      result=$(api POST /api/clients -H "Content-Type: application/json" -d "$body")
      echo "$result" | python3 -m json.tool

      local client_slug
      client_slug=$(echo "$result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('slug',''))")
      if [[ -n "$client_slug" ]]; then
        info "Portal link: https://revelstoke.webbedfilms.com/portal/${client_slug}"
      fi
      ;;
    delete)
      local slug="${1:?Usage: wf portal clients delete <slug>}"
      api DELETE "/api/clients/${slug}" | python3 -m json.tool
      ;;
    *) die "Unknown action: $action (list|create|delete)" ;;
  esac
}

cmd_portal_projects() {
  local client_slug="${1:?Usage: wf portal projects <client-slug> [action] [opts]}"; shift
  local action="${1:-list}"; shift || true
  ensure_auth
  case "$action" in
    list)
      api GET "/api/clients/${client_slug}/projects" | python3 -m json.tool
      ;;
    create)
      local title="" description=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --title)       title="$2"; shift 2 ;;
          --description) description="$2"; shift 2 ;;
          *) die "Unknown flag: $1" ;;
        esac
      done
      [[ -n "$title" ]] || die "Usage: wf portal projects <client> create --title 'Title'"

      local body
      body=$(python3 -c "
import json, sys
d = {'title': sys.argv[1]}
if sys.argv[2]: d['description'] = sys.argv[2]
print(json.dumps(d))
" "$title" "$description")

      api POST "/api/clients/${client_slug}/projects" \
        -H "Content-Type: application/json" -d "$body" | python3 -m json.tool
      ;;
    delete)
      local project_slug="${1:?Usage: wf portal projects <client> delete <project-slug>}"
      api DELETE "/api/clients/${client_slug}/projects/${project_slug}" | python3 -m json.tool
      ;;
    *) die "Unknown action: $action (list|create|delete)" ;;
  esac
}

cmd_portal_add_version() {
  local client_slug="${1:?Usage: wf portal add-version <client> <project> <video-file> [--note 'text']}"; shift
  local project_slug="${1:?Usage: wf portal add-version <client> <project> <video-file>}"; shift
  local file="" note=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --note) note="$2"; shift 2 ;;
      -*)     die "Unknown flag: $1" ;;
      *)
        if [[ -z "$file" ]]; then file="$1"; shift
        else die "Unexpected argument: $1"; fi
        ;;
    esac
  done
  [[ -n "$file" ]] || die "Usage: wf portal add-version <client> <project> <video-file> [--note 'text']"
  [[ -f "$file" ]] || die "File not found: $file"

  ensure_auth

  info "==> Uploading $(basename "$file")..."
  local upload_result
  upload_result=$(cmd_upload_raw "$file")
  local transcode_id
  transcode_id=$(echo "$upload_result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('transcodeId',''))")

  [[ -n "$transcode_id" ]] || die "Upload failed — no transcodeId"

  info "==> Transcoding..."
  local transcode_result
  transcode_result=$(cmd_transcode_wait_raw "$transcode_id")
  local video_path thumbnail_path
  video_path=$(echo "$transcode_result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('videoPath', '/assets/videos/' + d.get('output','')))")
  thumbnail_path=$(echo "$transcode_result" | python3 -c "import sys,json; print(json.load(sys.stdin).get('thumbnail',''))")

  info "==> Adding version to ${client_slug}/${project_slug}..."
  local body
  body=$(python3 -c "
import json, sys
d = {'file_path': sys.argv[1]}
if sys.argv[2]: d['thumbnail'] = sys.argv[2]
if sys.argv[3]: d['note'] = sys.argv[3]
print(json.dumps(d))
" "$video_path" "$thumbnail_path" "$note")

  api POST "/api/clients/${client_slug}/projects/${project_slug}/versions" \
    -H "Content-Type: application/json" -d "$body" | python3 -m json.tool

  info "==> Done! Version added."
}

cmd_portal_upload_resource() {
  local client_slug="${1:?Usage: wf portal upload-resource <client> <file> --category <cat>}"; shift
  local file="" category="other"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --category) category="$2"; shift 2 ;;
      -*)         die "Unknown flag: $1" ;;
      *)
        if [[ -z "$file" ]]; then file="$1"; shift
        else die "Unexpected argument: $1"; fi
        ;;
    esac
  done
  [[ -n "$file" ]] || die "Usage: wf portal upload-resource <client> <file> --category <cat>"
  [[ -f "$file" ]] || die "File not found: $file"

  ensure_auth
  info "Uploading resource $(basename "$file") to ${client_slug} (${category})..."
  api POST "/api/clients/${client_slug}/resources" \
    -F "file=@${file}" \
    -F "category=${category}" | python3 -m json.tool
}

cmd_portal_migrate() {
  local old_uuid="${1:?Usage: wf portal migrate-project <old-uuid> --client 'Client Name'}"; shift
  local client_name="" client_slug=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --client) client_name="$2"; shift 2 ;;
      --slug)   client_slug="$2"; shift 2 ;;
      *) die "Unknown flag: $1" ;;
    esac
  done
  [[ -n "$client_name" ]] || die "Usage: wf portal migrate-project <old-uuid> --client 'Client Name'"
  [[ -z "$client_slug" ]] && client_slug=$(slugify "$client_name")

  ensure_auth

  # Get old project
  info "Fetching old project ${old_uuid}..."
  local old_project
  old_project=$(api GET /api/projects | python3 -c "
import sys, json
projects = json.load(sys.stdin)
for p in projects:
    if p.get('uuid') == '$old_uuid':
        json.dump(p, sys.stdout)
        sys.exit(0)
print('null')
sys.exit(1)
" 2>/dev/null) || die "Old project not found: ${old_uuid}"

  local project_title
  project_title=$(echo "$old_project" | python3 -c "import sys,json; print(json.load(sys.stdin).get('title','Untitled'))")

  # Create or find client
  info "Ensuring client '${client_name}' exists..."
  local client_check
  client_check=$(api GET "/api/clients/${client_slug}" 2>/dev/null || echo '{"error":"not found"}')
  if echo "$client_check" | grep -q '"error"'; then
    info "Creating client: ${client_name}..."
    api POST /api/clients \
      -H "Content-Type: application/json" \
      -d "{\"name\":\"${client_name}\",\"slug\":\"${client_slug}\"}" > /dev/null
  fi

  # Create project under client
  local project_slug
  project_slug=$(slugify "$project_title")
  info "Creating project: ${project_title}..."
  api POST "/api/clients/${client_slug}/projects" \
    -H "Content-Type: application/json" \
    -d "{\"title\":\"${project_title}\"}" > /dev/null 2>&1 || true

  # Migrate versions
  info "Migrating versions..."
  local versions
  versions=$(api GET "/api/projects/${old_uuid}/versions")
  echo "$versions" | python3 -c "
import sys, json
versions = json.load(sys.stdin)
for v in sorted(versions, key=lambda x: x.get('version_number', 0)):
    print(json.dumps({'video': v['video'], 'thumbnail': v.get('thumbnail',''), 'note': v.get('note','')}))
" | while IFS= read -r version_json; do
    api POST "/api/clients/${client_slug}/projects/${project_slug}/versions" \
      -H "Content-Type: application/json" -d "$version_json" > /dev/null
    info "  Migrated version"
  done

  info "==> Migration complete! Portal: https://revelstoke.webbedfilms.com/portal/${client_slug}"
}

