# ── Dispatch ────────────────────────────────────────────
cmd="${1:-help}"; shift || true
case "$cmd" in
  login)          cmd_login "$@" ;;
  add)            cmd_add "$@" ;;
  films)          cmd_films "$@" ;;
  projects)       cmd_projects "$@" ;;
  upload)         cmd_upload "$@" ;;
  transcode)      cmd_transcode "$@" ;;
